# Fornitore di modello: anthropic | ollama | fake
LLM_PROVIDER=anthropic

# --- anthropic ---
# RS.4: selezionare un tier che NON conservi ne' addestri sul codice sorgente.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- vincoli ---
AGENT_TIMEOUT_S=45           # RQ.7, pensato per Claude (cloud, veloce)
OLLAMA_AGENT_TIMEOUT_S=300   # modello locale: molto piu' lento, anche con GPU
MAX_OUTPUT_TOKENS=4096
MAX_SCOPE_CHARS=180000
